# Copy this file to .env and fill in the values.

# Bazarr — Settings → General → Security → API Key
BAZARR_API_KEY=

# Radarr — Settings → General → Security → API Key
RADARR_API_KEY=

# Sonarr — Settings → General → Security → API Key
SONARR_API_KEY=

# Service URLs — only set these if not using Docker service names
# BAZARR_URL=http://bazarr:6767
# RADARR_URL=http://radarr:7878
# SONARR_URL=http://sonarr:8989

# Tuning — all optional, defaults shown
POLL_INTERVAL_MINUTES=15     # how often to poll (minutes)
GRACE_MINUTES=10             # wait after first seen before acting
RECHECK_COOLDOWN_HOURS=24    # minimum gap between re-checking the same item
DRY_RUN=true                 # set to false to enable real grabs

LANGUAGE_ALLOWLIST=          # comma-separated BCP-47 codes, e.g. fr,de — empty = all languages flagged missing by the item's Bazarr Language Profile

# STATE_PATH=/data/state.json  # path to the persistent state file (default shown)
